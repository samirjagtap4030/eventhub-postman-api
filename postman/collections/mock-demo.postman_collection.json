              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"pong\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Response has message field\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"message\");",
                  "    pm.expect(json.message).to.eql(\"pong\");",
                  "});",
                  "pm.test(\"Data types are correct\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.be.a(\"string\").and.to.not.be.empty;",
                  "});",
                  "pm.test(\"Content-Type is application/json\", () => {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});",
                  "pm.test(\"Response time under 1000ms\", () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ]
